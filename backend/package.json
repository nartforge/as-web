{
  "name": "@nartforge/backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "XDG_CACHE_HOME=.cache PRISMA_ENGINES_CACHE_DIR=.prisma-cache prisma generate && tsc",
    "start": "node dist/index.js",
    "prisma:generate": "XDG_CACHE_HOME=.cache PRISMA_ENGINES_CACHE_DIR=.prisma-cache prisma generate",
    "prisma:migrate": "XDG_CACHE_HOME=.cache PRISMA_ENGINES_CACHE_DIR=.prisma-cache prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
